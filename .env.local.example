# Synology NAS 설정
# NAS 외부 접근 주소 (DDNS 또는 고정 IP)
NAS_URL=https://your-nas.synology.me:5001

# NAS 계정 정보
NAS_ACCOUNT=your_username
NAS_PASSWORD=your_password

# NAS 업로드 경로 (공유 폴더 기준)
# 예: /volume1/lecture-notes 또는 /homes/username/lecture-notes
NAS_UPLOAD_PATH=/volume1/lecture-notes

# NAS 2단계 인증(OTP) 사용 시 Device Token
# /api/nas/setup 엔드포인트에서 OTP 코드로 발급받을 수 있습니다.
# NAS_DEVICE_TOKEN=발급받은_토큰값
